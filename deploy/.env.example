# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║  Environment Variables — Copy to .env and fill in values                    ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# ── Broker Credentials ───────────────────────────────────────────────────────
BROKER_TYPE=zerodha
BROKER_API_KEY=your_api_key_here
BROKER_API_SECRET=your_api_secret_here
BROKER_TOTP_SECRET=your_totp_base32_secret_here
BROKER_USER_ID=your_user_id
BROKER_PASSWORD=your_password

# ── Trading Configuration ────────────────────────────────────────────────────
TRADING_CAPITAL=1000000
MAX_DAILY_LOSS_PCT=0.02
MAX_OPEN_POSITIONS=10
DEFAULT_INDEX=NIFTY
PAPER_TRADING=true

# ── Strategy Toggles ─────────────────────────────────────────────────────────
ENABLE_STRADDLE=true
ENABLE_PAIRS=true
ENABLE_DISPERSION=false

# ── Infrastructure ───────────────────────────────────────────────────────────
GRPC_HOST=127.0.0.1
GRPC_PORT=50051
LOG_LEVEL=INFO
STATIC_IP=

# ── ML Model ─────────────────────────────────────────────────────────────────
MODEL_PATH=models/ddqn_v3.pt
USE_GPU=false
BAR_INTERVAL_MINUTES=15
LOOKBACK_BARS=100

# ── Data Provider ────────────────────────────────────────────────────────────
DATA_PROVIDER=truedata
TRUEDATA_USER=
TRUEDATA_PASSWORD=
DATA_CACHE_DIR=data/cache

# ── Dashboard & Remote Access ────────────────────────────────────────────────
# Set a secret key to protect your dashboard from unauthorized access
# Access via: https://yourdomain.com/live?key=YOUR_SECRET_KEY
DASHBOARD_API_KEY=change_this_to_a_random_string

# Cloudflare Tunnel token (optional, for HTTPS remote access)
# Get from: Cloudflare Zero Trust > Networks > Tunnels > Create
CLOUDFLARE_TUNNEL_TOKEN=

# ── Monitoring ───────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=admin
